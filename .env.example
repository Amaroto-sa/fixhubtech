# FixHub Platform Environment Variables

# DATABASE (Neon Serverless Postgres)
# Get this from your Neon console
DATABASE_URL="postgresql://user:password@hostname.neon.tech/dbname?sslmode=require"

# CLERK AUTHENTICATION
# Get these from your Clerk dashboard
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# CLERK WEBHOOK
# Needed for user synchronization. Get from Clerk Webhooks page.
CLERK_WEBHOOK_SECRET="whsec_..."

# EMAIL (Resend)
# Get from resend.com
RESEND_API_KEY="re_..."

# PAYMENTS (Flutterwave)
# Get from Flutterwave dashboard
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY="FLWPUBK_TEST-..."
FLUTTERWAVE_SECRET_KEY="FLWSECK_TEST-..."
FLUTTERWAVE_ENCRYPTION_KEY="..."
FLUTTERWAVE_WEBHOOK_HASH="your_custom_webhook_hash"

# APP URL
# Important for webhooks and absolute links
NEXT_PUBLIC_APP_URL="http://localhost:3000"
